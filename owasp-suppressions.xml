<?xml version="1.0" encoding="UTF-8"?>
<!--
    OWASP Dependency-Check için yanlış pozitif / kabul edilen risk listesi.

    Tarama komutu: mvn org.owasp:dependency-check-maven:check
    Rapor:         target/dependency-check-report.html

    HER bastırma için <notes> kısmına GEREKÇE ve gerekirse yeniden gözden
    geçirme tarihi yazın. Suppress = bu CVE'nin uygulanabilir olmadığını
    veya kabul edilen risk olduğunu beyan etmek.

    Yeniden değerlendirme tarihi: 2026-09-06 (her 3 ayda bir).
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- ============================================================
         POI — CVE-2025-31672 (sadece READ path)
         POI'yi yazma için kullanıyoruz, parse etmiyoruz. Uygulanmaz.
         ============================================================ -->
    <suppress until="2026-09-06Z">
        <notes>POI sadece WRITE yolu — readers'a maruz kalmıyor (Excel raporu üretiyoruz). 3 ayda re-evaluate.</notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.poi/poi(-ooxml(-lite)?)?@.*$</packageUrl>
        <cve>CVE-2025-31672</cve>
    </suppress>

    <!-- ============================================================
         kotlin-stdlib (ve jdk7/jdk8 varyantları) — CVE-2020-29582
         1.4.21 öncesinde tempfile TOCTOU. 2.0.21'e bump'lı; CPE match
         sürüm eşleştirme zayıflığından kaynaklanıyor. False positive.
         ============================================================ -->
    <suppress until="2026-09-06Z">
        <notes>kotlin-stdlib 2.0.21'e bump'lı. CVE 1.4.21 öncesi sürümler için. False positive (CPE drift). 3 ayda re-evaluate.</notes>
        <packageUrl regex="true">^pkg:maven/org\.jetbrains\.kotlin/kotlin-stdlib(-jdk7|-jdk8)?@.*$</packageUrl>
        <cve>CVE-2020-29582</cve>
    </suppress>

    <!-- ============================================================
         log4j-api 2.24.3 — CVE-2026-34477..34481, CVE-2025-68161
         Bu CVE'ler log4j-CORE içindir (log4j2 kendi appender'ları).
         Biz log4j-CORE KULLANMIYORUZ — sadece log4j-to-slf4j bridge'i
         var; tüm log'lar Logback'e yönlendiriliyor. log4j-api'de
         "lookup" ya da pattern parser yok. Uygulanmaz.
         ============================================================ -->
    <suppress until="2026-09-06Z">
        <notes>log4j-api only — log4j-core kullanmıyoruz, log'lar Logback'e gidiyor (log4j-to-slf4j bridge). CVE'ler core içindir. 3 ayda re-evaluate (yeni patch sürüm çıkınca düşür).</notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j-api@.*$</packageUrl>
        <cve>CVE-2026-34477</cve>
        <cve>CVE-2026-34478</cve>
        <cve>CVE-2026-34479</cve>
        <cve>CVE-2026-34480</cve>
        <cve>CVE-2026-34481</cve>
        <cve>CVE-2025-68161</cve>
    </suppress>

    <!-- ============================================================
         protobuf-java 3.25.6 — CVE-2026-0994
         Javalin'in transitive bağımlılığı; biz protobuf API'yi
         kullanmıyoruz (sadece Javalin'in iç haberleşmesi). Local
         (Tailscale arkasında) deployment'ta risk düşük.
         Yeniden değerlendir: protobuf 4.x'e geçince veya 3.25.7 çıkarsa.
         ============================================================ -->
    <suppress until="2026-09-06Z">
        <notes>Javalin iç dep; uygulamamız protobuf API çağrısı yapmıyor. Tailscale ağında bind 127.0.0.1; harici saldırı yüzeyi yok. 3 ayda re-evaluate.</notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf-java@.*$</packageUrl>
        <cve>CVE-2026-0994</cve>
    </suppress>

    <!-- ============================================================
         Jetty 11.0.25 — CVE-2026-2332, CVE-2026-5795, CVE-2025-5115,
                         CVE-2025-11143
         11.0.25 son 11.x sürümü; üst patch için Jetty 12'ye geçmek
         gerek (Javalin 6.x Jetty 11 kullanıyor, Javalin 7'ye geçiş gerekli).
         Mitigation: API_HTTP_ENABLED=false + API_BIND_ADDRESS=127.0.0.1
         + Tailscale Funnel/Serve arkasında HTTPS. Public internet'e
         maruz değil. Risk kabul ediliyor.
         Yeniden değerlendir: Javalin 7.x veya Jetty 12 geçişi
                              (gerekli refactoring var).
         ============================================================ -->
    <suppress until="2026-09-06Z">
        <notes>Jetty 11.x EOL. Mitigation: bind 127.0.0.1 + Tailscale + reverse proxy. Public internet maruziyeti yok. TODO: Javalin 7 + Jetty 12 migration (deploy sonrası ilk bakım turunda). 3 ayda re-evaluate.</notes>
        <packageUrl regex="true">^pkg:maven/org\.eclipse\.jetty(\.websocket)?/.*@.*$</packageUrl>
        <cve>CVE-2026-2332</cve>
        <cve>CVE-2026-5795</cve>
        <cve>CVE-2025-5115</cve>
        <cve>CVE-2025-11143</cve>
        <cve>CVE-2024-8184</cve>
    </suppress>

    <!-- ============================================================
         Angus Activation transitive 2.0.2 — CVE-2025-7962
         pom'da explicit 2.0.4 override eklendi; eğer scan hâlâ
         eski sürümü görüyorsa, m2 cache temizliği gerek:
            rm -rf ~/.m2/repository/org/eclipse/angus
            mvn dependency:purge-local-repository
         Bump'tan sonra suppress otomatik düşmeli; düşmüyorsa kalsın.
         ============================================================ -->
    <suppress until="2026-09-06Z">
        <notes>Angus Mail 2.0.4'e bump'lı. angus-activation 2.0.2 son sürüm (Maven Central'da 2.0.4 yayınlanmadı). 3 ayda re-evaluate.</notes>
        <packageUrl regex="true">^pkg:maven/org\.eclipse\.angus/angus-(activation|mail|core|logging-mailhandler)@.*$</packageUrl>
        <cve>CVE-2025-7962</cve>
    </suppress>

</suppressions>
